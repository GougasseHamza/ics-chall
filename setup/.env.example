# Public host ports. Modbus/TCP is deliberately never published.
SCADA_PORT=8089
CHECKER_PORT=8090
PLAYER_SSH_PORT=2224

# Intended public challenge credential, not an infrastructure secret.
PLAYER_PASSWORD=line4-maint

# Replace both values before deployment. scripts/deploy.sh can generate them.
PLANT_API_TOKEN=replace-with-a-random-plant-token
FLAG_SECRET=replace-with-a-random-flag-secret
INSTANCE_ID=last-bottle-01
FLAG_PREFIX=flag
